// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id        String    @id @db.VarChar(36)
  username  String    @unique @db.VarChar(50)
  password  String    @db.VarChar(255)
  email     String?   @unique @db.VarChar(100)
  avatar    String    @default("") @db.VarChar(500)
  status    Int       @default(1) @db.TinyInt
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  lastLogin DateTime? @map("last_login")

  tokens UserTokens[]
  posts BlogPost[]
  comments BlogComment[]
  likes BlogLike[]

  @@index([username], name: "idx_username")
  @@index([email], name: "idx_email")
  @@map("users")
}

model UserTokens {
  id         String   @id @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  token      String   @db.VarChar(500)
  tokenType  String   @default("access") @map("token_type") @db.VarChar(20)
  deviceInfo String?  @map("device_info") @db.VarChar(200)
  expiresAt  DateTime @map("expires_at") @db.DateTime
  createdAt  DateTime @default(now()) @map("created_at")

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token(255)], name: "idx_token")
  @@index([userId], name: "idx_user_id")
  @@map("user_tokens")
}

model BlogPost {
  id          String   @id @db.VarChar(36)
  title       String   @db.VarChar(255)
  excerpt     String   @db.Text
  cover       String?  @db.VarChar(1000)
  authorId    String   @map("author_id") @db.VarChar(36)
  authorName  String   @map("author_name") @db.VarChar(50)
  authorAvatar String?  @map("author_avatar") @db.VarChar(500)
  tags        String   @db.Text
  likes       Int      @default(0) @db.Int
  comments    Int      @default(0) @db.Int
  createdAt   DateTime @default(now()) @map("created_at")

  author Users @relation(fields: [authorId], references: [id])
  commentRecords BlogComment[]
  likeRecords BlogLike[]

  @@index([authorId], name: "idx_author_id")
  @@map("blog_posts")
}

model BlogComment {
  id        String   @id @db.VarChar(36)
  blogId    String   @map("blog_id") @db.VarChar(36)
  authorId  String   @map("author_id") @db.VarChar(36)
  authorName String  @map("author_name") @db.VarChar(50)
  authorAvatar String? @map("author_avatar") @db.VarChar(500)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  blog   BlogPost @relation(fields: [blogId], references: [id], onDelete: Cascade, map: "fk_blog_comment_blog")
  author Users @relation(fields: [authorId], references: [id], map: "fk_blog_comment_author")

  @@index([blogId], name: "idx_blog_id")
  @@index([authorId], name: "idx_comment_author")
  @@map("blog_comments")
}

model BlogLike {
  id        String   @id @db.VarChar(36)
  blogId    String   @map("blog_id") @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  blog  BlogPost @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user  Users @relation(fields: [userId], references: [id])

  @@unique([blogId, userId], name: "uniq_blog_user_like")
  @@index([blogId], name: "idx_like_blog_id")
  @@index([userId], name: "idx_like_user_id")
  @@map("blog_likes")
}
